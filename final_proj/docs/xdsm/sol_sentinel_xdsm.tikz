&
&
&
&
&
&
&
\\
};

% XDSM process chains
{ [start chain=process]
 \begin{pgfonlayer}{process} 
\chainin (SOL);
\chainin (COM) [join=by ProcessHVA];
\chainin (PWR) [join=by ProcessHVA];
\chainin (THM) [join=by ProcessHVA];
\chainin (ORB) [join=by ProcessHVA];
\chainin (PRP) [join=by ProcessHVA];
\chainin (BDG) [join=by ProcessHVA];
\chainin (SOL) [join=by ProcessHVA];
\end{pgfonlayer}
}

\begin{pgfonlayer}{data}
\path
% Horizontal edges
(SOL) edge [DataLine] (SOL-COM)
(SOL) edge [DataLine] (SOL-PWR)
(SOL) edge [DataLine] (SOL-THM)
(SOL) edge [DataLine] (SOL-BDG)
(COM) edge [DataLine] (COM-PWR)
(PWR) edge [DataLine] (PWR-THM)
(PWR) edge [DataLine] (PWR-ORB)
(THM) edge [DataLine] (THM-ORB)
(ORB) edge [DataLine] (ORB-PRP)
(COM) edge [DataLine] (COM-BDG)
(PWR) edge [DataLine] (PWR-BDG)
(THM) edge [DataLine] (THM-BDG)
(PRP) edge [DataLine] (PRP-BDG)
(PRP) edge [DataLine] (PRP-PWR)
(BDG) edge [DataLine] (BDG-ORB)
(BDG) edge [DataLine] (BDG-PRP)
(BDG) edge [DataLine] (right_output_BDG)
% Vertical edges
(SOL-COM) edge [DataLine] (COM)
(SOL-PWR) edge [DataLine] (PWR)
(SOL-THM) edge [DataLine] (THM)
(SOL-BDG) edge [DataLine] (BDG)
(COM-PWR) edge [DataLine] (PWR)
(PWR-THM) edge [DataLine] (THM)
(PWR-ORB) edge [DataLine] (ORB)
(THM-ORB) edge [DataLine] (ORB)
(ORB-PRP) edge [DataLine] (PRP)
(COM-BDG) edge [DataLine] (BDG)
(PWR-BDG) edge [DataLine] (BDG)
(THM-BDG) edge [DataLine] (BDG)
(PRP-BDG) edge [DataLine] (BDG)
(PRP-PWR) edge [DataLine] (PWR)
(BDG-ORB) edge [DataLine] (ORB)
(BDG-PRP) edge [DataLine] (PRP)
(SOL) edge [DataLine] (output_SOL)
(ORB) edge [DataLine] (output_ORB);
\end{pgfonlayer}

\end{tikzpicture}
