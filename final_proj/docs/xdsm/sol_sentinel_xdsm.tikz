\begin{tikzpicture}

\matrix[MatrixSetup]{
%Row 0
\node [DataIO] (output_SOL) {$\begin{array}{c}\text{Mission req.} \\ \text{fixed assumptions}\end{array}$};&
&
&
&
\node [DataIO] (output_ORB) {$\begin{array}{c}\text{Basilisk SRP} \\ \text{surrogate}\end{array}$};&
&
&
&
\\
%Row 1
\node [MDA] (SOL) {$\begin{array}{c}\text{Fixed-Point} \\ \text{Sizing Solver}\end{array}$};&
\node [DataInter] (SOL-COM) {$R_{L4}, DataRate$};&
\node [DataInter] (SOL-PWR) {$P_{payload}$};&
\node [DataInter] (SOL-THM) {$T_{req}$};&
&
&
\node [DataInter] (SOL-BDG) {$M_{payload}, V_{payload}$};&
&
\\
%Row 2
&
\node [Function] (COM) {$\text{Comms}$};&
\node [DataInter] (COM-PWR) {$P_{tx}$};&
&
&
&
\node [DataInter] (COM-BDG) {$M_{com}, V_{com}$};&
&
\\
%Row 3
&
&
\node [Function] (PWR) {$\text{Power}$};&
\node [DataInter] (PWR-THM) {$A_{sa}, P_{dissipated}$};&
\node [DataInter] (PWR-ORB) {$A_{sa}$};&
&
\node [DataInter] (PWR-BDG) {$M_{pwr}, V_{pwr}$};&
&
\\
%Row 4
&
&
&
\node [Function] (THM) {$\text{Thermal}$};&
\node [DataInter] (THM-ORB) {$\rho_{eff}$};&
&
\node [DataInter] (THM-BDG) {$M_{thm}, V_{thm}$};&
&
\\
%Row 5
&
&
&
&
\node [Function] (ORB) {$\begin{array}{c}\text{Orbit SRP} \\ \text{Surrogate}\end{array}$};&
\node [DataInter] (ORB-PRP) {$\Delta V_{avg}$};&
&
&
\\
%Row 6
&
&
\node [DataInter] (PRP-PWR) {$P_{ion}, t_{burn}$};&
&
&
\node [Function] (PRP) {$\text{Propulsion}$};&
\node [DataInter] (PRP-BDG) {$M_{prop}, V_{prop}$};&
&
\\
%Row 7
&
&
&
&
\node [DataInter] (BDG-ORB) {$M_{tot}$};&
\node [DataInter] (BDG-PRP) {$M_{tot}$};&
\node [Function] (BDG) {$\begin{array}{c}\text{6U Budget} \\ \text{Closure}\end{array}$};&
