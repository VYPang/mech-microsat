      <demosection>
         <label>AttitudeControl</label>
         <demoitem>
            <label>DisturbancesDemo: Example CubeSat disturbance analysis</label>
            <callback>DisturbancesDemo</callback>
            <file>../CubeSat/Demos/AttitudeControl/html/DisturbancesDemo.html</file>
         </demoitem>
         <demoitem>
            <label>DisturbancesSolarWings: CubeSat disturbance analysis with deployable solar panels</label>
            <callback>DisturbancesSolarWings</callback>
            <file>../CubeSat/Demos/AttitudeControl/html/DisturbancesSolarWings.html</file>
         </demoitem>
         <demoitem>
            <label>MagneticControlDemo: Magnetic control demand analysis</label>
            <callback>MagneticControlDemo</callback>
            <file>../CubeSat/Demos/AttitudeControl/html/MagneticControlDemo.html</file>
         </demoitem>
         <demoitem>
            <label>NanoSatSimulation: Demonstrate NanoSat attitude control reaction wheels.</label>
            <callback>NanoSatSimulation</callback>
            <file>../CubeSat/Demos/AttitudeControl/html/NanoSatSimulation.html</file>
         </demoitem>
