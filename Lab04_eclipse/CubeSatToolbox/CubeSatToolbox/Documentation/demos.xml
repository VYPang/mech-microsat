         <demoitem>
            <label>CubeSatTiltedWings: Design a 3U CubeSat with Tilted Wings</label>
            <callback>CubeSatTiltedWings</callback>
            <file>../CubeSat/Demos/Design/html/CubeSatTiltedWings.html</file>
