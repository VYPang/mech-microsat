            <file>../CubeSat/Demos/Simulation/html/MagneticHysteresisOrbit.html</file>
         </demoitem>
         <demoitem>
            <label>MomentumManagement: Demonstrate simple dipole based momentum management</label>
            <callback>MomentumManagement</callback>
            <file>../CubeSat/Demos/Simulation/html/MomentumManagement.html</file>
         </demoitem>
         <demoitem>
            <label>RadiationDisturbance: Radiation pressure disturbance demo.</label>
            <callback>RadiationDisturbance</callback>
            <file>../CubeSat/Demos/Simulation/html/RadiationDisturbance.html</file>
         </demoitem>
         <demoitem>
            <label>SpacecraftWithDamping: A spacecraft with rate or hysteresis damping.</label>
            <callback>SpacecraftWithDamping</callback>
            <file>../CubeSat/Demos/Simulation/html/SpacecraftWithDamping.html</file>
         </demoitem>
         <demoitem>
            <label>TubeSatSimulation: Demonstrate a TubeSat attitude and power system dynamics.</label>
            <callback>TubeSatSimulation</callback>
            <file>../CubeSat/Demos/Simulation/html/TubeSatSimulation.html</file>
         </demoitem>
         <demoitem>
            <label>TwoSpacecraftOrbitSimulation: Demonstrate a 2 satellite CubeSat constellation.</label>
            <callback>TwoSpacecraftOrbitSimulation</callback>
            <file>../CubeSat/Demos/Simulation/html/TwoSpacecraftOrbitSimulation.html</file>
         </demoitem>
         <demoitem>
            <label>TwoSpacecraftSimpleOrbitSimulation: Demonstrate a 2 satellite CubeSat constellation</label>
            <callback>TwoSpacecraftSimpleOrbitSimulation</callback>
            <file>../CubeSat/Demos/Simulation/html/TwoSpacecraftSimpleOrbitSimulation.html</file>
         </demoitem>
