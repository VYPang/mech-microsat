            <callback>CubeSatRWASimulation</callback>
            <file>../CubeSat/Demos/Simulation/html/CubeSatRWASimulation.html</file>
         </demoitem>
         <demoitem>
            <label>CubeSatSimulation: Demonstrate a CubeSat attitude and power system dynamics.</label>
            <callback>CubeSatSimulation</callback>
            <file>../CubeSat/Demos/Simulation/html/CubeSatSimulation.html</file>
         </demoitem>
         <demoitem>
            <label>MagneticHysteresisOrbit: Magnetic hysteresis over multiple orbits.</label>
