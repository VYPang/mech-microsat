         <demoitem>
            <label>CubeSatFaceTemperaturesDemo: Demonstrate temperatures of faces of a CubeSat</label>
            <callback>CubeSatFaceTemperaturesDemo</callback>
            <file>../CubeSat/Demos/Thermal/html/CubeSatFaceTemperaturesDemo.html</file>
         </demoitem>
         <demoitem>
            <label>IsothermalCubeSatDemo: Isothermal satellite demo</label>
            <callback>IsothermalCubeSatDemo</callback>
            <file>../CubeSat/Demos/Thermal/html/IsothermalCubeSatDemo.html</file>
